# Máy thật / cùng WiFi: dùng IP LAN máy chạy backend (ipconfig), KHÔNG dùng localhost — app không gọi được localhost của PC.
EXPO_PUBLIC_HOST_BE=localhost
EXPO_PUBLIC_PORT_BE=8087
EXPO_PUBLIC_MOCK_MODE=true

# Dev (Expo): để trống hoặc 0 — app ưu tiên IP từ Expo (hostUri), tránh .env cũ sai IP → ERR_NETWORK khi upload/tạo nhóm.
# Đặt 1 nếu backend chạy máy khác (không cùng máy Metro) và bắt buộc dùng EXPO_PUBLIC_HOST_BE.
# EXPO_PUBLIC_FORCE_ENV_HOST=1

# Gốc HTTPS/HTTP nơi public trang WebRTC (tunnel Loophole, ngrok, bản deploy...). Không dấu / cuối.
# Để trống: dùng http://EXPO_PUBLIC_HOST_BE:EXPO_PUBLIC_PORT_BE
# EXPO_PUBLIC_WEBRTC_CALL_ORIGIN=https://xxxx.loophole.site
